{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && npx -y pnpm@9.15.9 install --frozen-lockfile",
  "buildCommand": "cd ../.. && npx -y pnpm@9.15.9 -w run build:vercel:widget",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
