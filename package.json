{
  "name": "schedule-react-nest",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:vercel": "node scripts/vercel-build.mjs",
    "dev": "turbo run dev --filter=web --filter=api",
    "dev:web": "pnpm --filter web dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "generate:api": "pnpm --filter @repo/domain build && pnpm --filter api generate:vivacrm && pnpm --filter api generate:padlhub && pnpm --filter api openapi:generate && pnpm --filter web generate:api"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.x",
    "pnpm": "9.15.9"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "widgets/*"
  ]
}
