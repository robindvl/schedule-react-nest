{
  "openapi": "3.0.0",
  "paths": {
    "/api": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/api/trainings": {
      "get": {
        "operationId": "findAllTrainings",
        "parameters": [
          {
            "name": "date",
            "required": true,
            "in": "query",
            "description": "Calendar date (YYYY-MM-DD)",
            "schema": {
              "example": "2026-06-02",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TrainingDataDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Query parameter \"date\" is required"
          }
        },
        "summary": "",
        "tags": [
          "trainings"
        ]
      }
    },
    "/api/trainings/first": {
      "get": {
        "operationId": "findFirstTrainings",
        "parameters": [
          {
            "name": "date",
            "required": true,
            "in": "query",
            "description": "Calendar date (YYYY-MM-DD)",
            "schema": {
              "example": "2026-06-02",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TrainingDataDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Query parameter \"date\" is required"
          }
        },
        "summary": "",
        "tags": [
          "trainings"
        ]
      }
    },
    "/api/trainings/{id}": {
      "get": {
        "operationId": "findTrainingById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrainingDataDto"
                }
              }
            }
          },
          "404": {
            "description": "Training not found"
          }
        },
        "summary": "",
        "tags": [
          "trainings"
        ]
      }
    },
    "/api/tournaments": {
      "get": {
        "operationId": "findAllTournaments",
        "parameters": [
          {
            "name": "date",
            "required": true,
            "in": "query",
            "description": "Calendar date (YYYY-MM-DD)",
            "schema": {
              "example": "2026-06-01",
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "description": "Comma-separated tournament statuses (filtered after fetch)",
            "schema": {
              "example": "REGISTRATION,RUNNING",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TournamentDataDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Query parameter \"date\" is required"
          }
        },
        "summary": "",
        "tags": [
          "tournaments"
        ]
      }
    },
    "/api/tournaments/{id}": {
      "get": {
        "operationId": "findTournamentById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TournamentDataDto"
                }
              }
            }
          },
          "404": {
            "description": "Tournament not found"
          }
        },
        "summary": "",
        "tags": [
          "tournaments"
        ]
      }
    }
  },
