# Nest API (прокси VivaCRM / PadlHub). Пути в SDK уже с префиксом /api.
# Локально оставьте пустым — Vite проксирует /api → http://localhost:5000
VITE_API_BASE_URL=

# Продакшен (Vercel → Settings → Environment Variables):
# VITE_API_BASE_URL=https://your-nest-api.example.com

# Remote виджета (только production build; dev — localhost:5001 в vite.config)
# VITE_TOURNAMENT_WIDGET_REMOTE=/mf-widget/remoteEntry.js
